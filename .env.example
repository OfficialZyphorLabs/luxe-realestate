# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
# Neon.tech recommended: https://neon.tech (free serverless PostgreSQL)
# Copy the "pooled" connection string here.
DATABASE_URL="postgresql://username:password@host:5432/luxereal?sslmode=require"

# Neon only — uncomment and set to the non-pooled (direct) URL for migrations.
# DIRECT_URL="postgresql://username:password@host:5432/luxereal?sslmode=require"

# ─── NextAuth / Auth.js v5 ──────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
# v5 reads AUTH_SECRET / AUTH_URL (NEXTAUTH_* are still accepted as aliases).
AUTH_SECRET="replace-with-32-char-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth — optional, enables "Continue with Google" login.
# Create credentials at https://console.cloud.google.com
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier allows 3,000 emails/month.
# Optional in dev: if RESEND_API_KEY is unset, emails are logged to the console
# instead of being sent, so registration/invite/reset flows still work locally.
RESEND_API_KEY="re_..."
# From identity for transactional email. Use a verified domain in production.
EMAIL_FROM="LuxeReal <onboarding@resend.dev>"

# ─── Cache & Rate Limiting (Upstash Redis) ──────────────────────────────────
# Sign up at https://upstash.com — free tier available.
# Create a Redis database → copy REST URL and token here.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ─── File Storage — image uploads (MVP) ─────────────────────────────────────
# Optional: without these, the listing form falls back to pasting image URLs.
# Set EITHER the Cloudflare R2 block OR the AWS S3 block (R2 preferred — cheaper,
# S3-compatible). The bucket must be publicly readable (or fronted by a public
# CDN/custom domain); *_PUBLIC_URL is the base your objects are served from.
#
# Cloudflare R2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=luxereal
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev
#
# AWS S3 (alternative):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=luxereal
# S3_PUBLIC_URL=https://luxereal.s3.amazonaws.com

# ─── AI — listing description generator (MVP) ───────────────────────────────
# Optional: without ANTHROPIC_API_KEY, the "Generate with AI" button is hidden
# and nothing else changes. Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# Model override (default: claude-opus-4-8). Use a cheaper/faster tier for this
# high-volume, low-complexity task if you prefer, e.g. claude-sonnet-5.
# ANTHROPIC_MODEL=claude-opus-4-8

# ─── Stripe (Phase 5 — billing) ─────────────────────────────────────────────
# Optional in dev: if STRIPE_SECRET_KEY is unset, billing degrades gracefully —
# the Change plan / Manage subscription actions return a friendly "not
# configured" message and the webhook acknowledges-and-ignores events.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Webhook signing secret. Local: `stripe listen --forward-to
# localhost:3000/api/webhooks/stripe` prints a whsec_… ; in prod, copy it from
# the Stripe Dashboard endpoint (URL: <AUTH_URL>/api/webhooks/stripe).
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Price IDs for each self-serve plan (create Products + recurring Prices in the
# Stripe Dashboard, then paste the price_… ids). ENTERPRISE is sales-led (none).
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
